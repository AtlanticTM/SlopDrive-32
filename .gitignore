.pio
.clinerules
CLAUDE.md
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch
.VSCodeCounter/
.gitignore
.cache/
.claude/

# Real secrets - never commit. Use secrets.example.h as the shared template.
include/secrets.h
secrets.h

# WebUI build artifacts — generated by build_webui.py at compile time :3
webui/node_modules/
webui/dist/
webui/.env.local

# LittleFS data artifacts — generated by build pipeline, not hand-edited
data/index.html
data/index.html.gz

# Dev tools & diagnostic scripts — not part of the firmware.
# (tools/* not tools/ so specific files CAN be re-included below —
#  git cannot re-include anything under an excluded directory.)
tools/*
# SlopSync registry codegen IS part of the repo: spec<->code lockstep tool.
!tools/gen_registry_header.py
.clangd
.clang-format
.cache/

# Python cache
__pycache__/
*.pyc

# Working docs, audits, plans & UI mockups — scratch, not firmware
SD32-*.md
sd32-preview-*.html
waypoint_kinematics_audit.md
graph_screenshot_temp.html
compile_commands.json
NewPCB.md
HANDOFF.md
plan.md
PLAN_NewPCB_Migration.md
PLAN_OSSM_Parity.md

# Reference hardware docs / binaries — not source
PCB Layout.diy
AIM_servo_modbus_reference.md
AIM_Servo_Motor_Datasheet_EN_with_images.pdf

# Build outputs, captures & scratch artifacts — generated, not source
build/
$null
